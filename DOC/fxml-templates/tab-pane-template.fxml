<?xml version="1.0" encoding="UTF-8"?>

<!--
  Tab 切换模板：TabPane + 多个 Tab
  适用模块：基础数据管理（科室/医生/排班）
  
  使用说明：
  1. 复制此文件并重命名为你的模块视图（如 BasicDataView.fxml）
  2. 修改 fx:controller 指向你的 Controller 全限定类名
  3. 每个 Tab 内可以放置独立的布局（如 SplitPane、VBox 等）
  4. 所有 Tab 共享同一个 Controller
-->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.medicare.controller.YourController"
         tabClosingPolicy="UNAVAILABLE"
         prefWidth="1000" prefHeight="700">

    <!-- ====== Tab 1：第一个管理页面 ====== -->
    <Tab text="Tab标题1">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <!-- 工具栏 -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch1" promptText="搜索关键字" prefWidth="200"/>
                <Button text="查询" onAction="#handleSearch1" styleClass="btn-primary"/>
                <Button text="新增" onAction="#handleNew1" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount1" text="共 0 条"/>
            </HBox>
            <!-- 内容区：可以是 SplitPane 或 TableView -->
            <TableView fx:id="table1" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="col1Id" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="col1Name" text="名称" prefWidth="150"/>
                    <TableColumn fx:id="col1Desc" text="描述" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </Tab>

    <!-- ====== Tab 2：第二个管理页面 ====== -->
    <Tab text="Tab标题2">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch2" promptText="搜索关键字" prefWidth="200"/>
                <ComboBox fx:id="cmbFilter2" promptText="筛选条件" prefWidth="150"/>
                <Button text="查询" onAction="#handleSearch2" styleClass="btn-primary"/>
                <Button text="新增" onAction="#handleNew2" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount2" text="共 0 条"/>
            </HBox>
            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                <TableView fx:id="table2">
                    <columns>
                        <TableColumn fx:id="col2Id" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="col2Name" text="名称" prefWidth="120"/>
                        <TableColumn fx:id="col2Status" text="状态" prefWidth="80"/>
                    </columns>
                </TableView>
                <!-- 右侧表单区 -->
                <VBox spacing="10" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="编辑区" styleClass="form-title"/>
                    <GridPane vgap="10" hgap="10">
                        <Label text="名称*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtName2" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="状态" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbStatus2" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="保存" onAction="#handleSave2" styleClass="btn-primary"/>
                        <Button text="删除" onAction="#handleDelete2" styleClass="btn-danger"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </VBox>
    </Tab>

    <!-- ====== Tab 3：第三个管理页面 ====== -->
    <Tab text="Tab标题3">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <!-- 按需添加内容 -->
            <Label text="第三个 Tab 的内容" alignment="CENTER"/>
        </VBox>
    </Tab>

</TabPane>
