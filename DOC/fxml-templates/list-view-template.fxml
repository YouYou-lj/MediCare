<?xml version="1.0" encoding="UTF-8"?>

<!--
  列表视图模板：全宽表格 + 顶部工具栏
  适用模块：患者管理、药品库存、病历管理
  
  使用说明：
  1. 复制此文件并重命名为你的模块视图（如 PatientView.fxml）
  2. 修改 fx:controller 指向你的 Controller 全限定类名
  3. 修改 TableColumn 的 fx:id 和 text，与你的实体类属性对应
  4. 如果需要操作列（编辑/删除按钮），保留 colAction 列
-->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.YourController"
            prefWidth="1000" prefHeight="700">

    <!-- 顶部工具栏 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="模块标题" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="新增" onAction="#handleNew" styleClass="btn-success"/>
                <TextField fx:id="txtSearch" promptText="搜索关键字" prefWidth="200"/>
                <Button text="查询" onAction="#handleSearch" styleClass="btn-primary"/>
                <Button text="刷新" onAction="#handleRefresh"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间内容：全宽表格 -->
    <center>
        <VBox spacing="5">
            <padding>
                <Insets top="5" right="15" bottom="5" left="15"/>
            </padding>
            <TableView fx:id="tableData" VBox.vgrow="ALWAYS">
                <columns>
                    <!-- 根据实体类属性修改 fx:id 和 text -->
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colField1" text="字段1" prefWidth="120"/>
                    <TableColumn fx:id="colField2" text="字段2" prefWidth="120"/>
                    <TableColumn fx:id="colField3" text="字段3" prefWidth="150"/>
                    <TableColumn fx:id="colField4" text="字段4" prefWidth="150"/>
                    <TableColumn fx:id="colField5" text="字段5" prefWidth="150"/>
                    <!-- 操作列：编辑 + 删除按钮 -->
                    <TableColumn fx:id="colAction" text="操作" prefWidth="140"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label fx:id="lblRecordCount" text="共 0 条记录"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
