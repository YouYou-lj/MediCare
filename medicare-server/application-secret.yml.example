# AI 配置示例文件
# 使用方式：复制本文件为 application-secret.yml，并填入你的真实密钥与模型信息
# 注意：application-secret.yml 已被 .gitignore 忽略，请勿提交到 Git 仓库

ai:
  # AI 服务提供商标识，仅用于日志展示
  provider: openai

  # API 密钥（必填）
  # 请替换为你的 OpenAI 或兼容 OpenAI 接口的密钥
  api-key: sk-your-api-key-here

  # 对话模型名称
  # 示例：gpt-4o-mini、gpt-4o、deepseek-chat、qwen-max 等
  model: gpt-4o-mini

  # Embedding 模型名称
  # 示例：text-embedding-3-small、text-embedding-3-large 等
  embedding-model: text-embedding-3-small

  # OpenAI 兼容接口地址（必填）
  # 如果使用 OpenAI 官方服务，保持 https://api.openai.com/v1
  # 如果使用国内兼容服务（如 DeepSeek、阿里百炼等），请替换为对应地址
  base-url: https://api.openai.com/v1

  # 请求超时时间
  timeout: 20s
