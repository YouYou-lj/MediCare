<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.StockDialogController"
            prefWidth="480" prefHeight="360">

    <content>
        <GridPane vgap="10" hgap="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="药品名称" GridPane.rowIndex="0" GridPane.columnIndex="0" minWidth="65"/>
            <TextField fx:id="txtMedName" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="当前库存" GridPane.rowIndex="0" GridPane.columnIndex="2" minWidth="65"/>
            <TextField fx:id="txtCurrentStock" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="操作类型*" GridPane.rowIndex="1" GridPane.columnIndex="0" minWidth="65"/>
            <ComboBox fx:id="cmbOpType" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="数量*" GridPane.rowIndex="1" GridPane.columnIndex="2" minWidth="50"/>
            <Spinner fx:id="spinQty" GridPane.rowIndex="1" GridPane.columnIndex="3" editable="true"/>

            <Label text="批号" GridPane.rowIndex="2" GridPane.columnIndex="0" minWidth="40"/>
            <TextField fx:id="txtBatchNo" promptText="请输入批号" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="有效期" GridPane.rowIndex="2" GridPane.columnIndex="2" minWidth="50"/>
            <DatePicker fx:id="dpExpiry" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            <Label text="操作人" GridPane.rowIndex="3" GridPane.columnIndex="0" minWidth="50"/>
            <TextField fx:id="txtOperator" promptText="请输入操作人" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="备注" GridPane.rowIndex="3" GridPane.columnIndex="2" minWidth="40"/>
            <TextField fx:id="txtRemark" promptText="请输入备注" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

            <Label fx:id="lblMessage" text="" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="4"/>
        </GridPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
