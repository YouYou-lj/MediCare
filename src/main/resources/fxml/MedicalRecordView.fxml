<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.MedicalRecordController"
            prefWidth="1000" prefHeight="700">

    <!-- 顶部工具栏 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="病历管理" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearch" promptText="患者/医生/诊断/主诉" prefWidth="220"/>
                <Button text="查询" onAction="#handleSearch" styleClass="btn-primary"/>
                <Button text="刷新" onAction="#handleRefresh"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间内容：全宽表格 -->
    <center>
        <VBox spacing="5">
            <padding>
                <Insets top="5" right="15" bottom="5" left="15"/>
            </padding>
            <TableView fx:id="tableRecords" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colPatient" text="患者" prefWidth="90"/>
                    <TableColumn fx:id="colDoctor" text="医生" prefWidth="90"/>
                    <TableColumn fx:id="colChief" text="主诉" prefWidth="180"/>
                    <TableColumn fx:id="colDiagnosis" text="诊断" prefWidth="180"/>
                    <TableColumn fx:id="colCreateTime" text="创建时间" prefWidth="140"/>
                    <TableColumn fx:id="colAction" text="操作" prefWidth="140"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label fx:id="lblRecordCount" text="共 0 条记录"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
