<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.medicare.controller.BasicDataController"
         tabClosingPolicy="UNAVAILABLE"
         prefWidth="1000" prefHeight="700">

    <!-- ====== 科室管理 Tab ====== -->
    <Tab text="科室管理">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtDeptSearch" promptText="科室名称" prefWidth="200"/>
                <Button text="查询" onAction="#handleDeptSearch" styleClass="btn-primary"/>
                <Button text="新增" onAction="#handleDeptNew" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblDeptCount" text="共 0 条"/>
            </HBox>
            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableDepartments">
                    <columns>
                        <TableColumn fx:id="colDeptId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colDeptName" text="科室名称" prefWidth="150"/>
                        <TableColumn fx:id="colDeptLocation" text="位置" prefWidth="200"/>
                        <TableColumn fx:id="colDeptPhone" text="电话" prefWidth="150"/>
                    </columns>
                </TableView>
                <VBox spacing="10" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="科室信息编辑" styleClass="form-title"/>
                    <GridPane vgap="10" hgap="10">
                        <Label text="科室名称*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDeptName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="位置" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDeptLocation" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="联系电话" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDeptPhone" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="lblDeptMessage" text=""/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="保存" onAction="#handleDeptSave" styleClass="btn-primary"/>
                        <Button text="清除" onAction="#handleDeptClear"/>
                        <Button text="删除" onAction="#handleDeptDelete" styleClass="btn-danger"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </VBox>
    </Tab>

    <!-- ====== 医生管理 Tab ====== -->
    <Tab text="医生管理">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtDoctorSearch" promptText="医生姓名" prefWidth="200"/>
                <ComboBox fx:id="cmbDoctorDeptFilter" promptText="全部科室" prefWidth="150"/>
                <Button text="查询" onAction="#handleDoctorSearch" styleClass="btn-primary"/>
                <Button text="新增" onAction="#handleDoctorNew" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblDoctorCount" text="共 0 条"/>
            </HBox>
            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableDoctors">
                    <columns>
                        <TableColumn fx:id="colDoctorId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colDoctorName" text="姓名" prefWidth="100"/>
                        <TableColumn fx:id="colDoctorDept" text="所属科室" prefWidth="120"/>
                        <TableColumn fx:id="colDoctorTitle" text="职称" prefWidth="120"/>
                        <TableColumn fx:id="colDoctorStatus" text="状态" prefWidth="80"/>
                    </columns>
                </TableView>
                <VBox spacing="10" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="医生信息编辑" styleClass="form-title"/>
                    <GridPane vgap="10" hgap="10">
                        <Label text="姓名*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDoctorName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="所属科室*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbDoctorDept" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="职称*" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbDoctorTitle" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="状态" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbDoctorStatus" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="lblDoctorMessage" text=""/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="保存" onAction="#handleDoctorSave" styleClass="btn-primary"/>
                        <Button text="清除" onAction="#handleDoctorClear"/>
                        <Button text="删除" onAction="#handleDoctorDelete" styleClass="btn-danger"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </VBox>
    </Tab>

    <!-- ====== 排班管理 Tab ====== -->
    <Tab text="排班管理">
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <DatePicker fx:id="dpScheduleDate" promptText="选择日期"/>
                <ComboBox fx:id="cmbScheduleDeptFilter" promptText="全部科室" prefWidth="150"/>
                <Button text="查询" onAction="#handleScheduleSearch" styleClass="btn-primary"/>
                <Button text="新增" onAction="#handleScheduleNew" styleClass="btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblScheduleCount" text="共 0 条"/>
            </HBox>
            <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableSchedules">
                    <columns>
                        <TableColumn fx:id="colScheduleId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colScheduleDate" text="日期" prefWidth="100"/>
                        <TableColumn fx:id="colScheduleDoctor" text="医生" prefWidth="100"/>
                        <TableColumn fx:id="colScheduleDept" text="科室" prefWidth="100"/>
                        <TableColumn fx:id="colScheduleSlot" text="时段" prefWidth="80"/>
                        <TableColumn fx:id="colScheduleTotal" text="总号源" prefWidth="70"/>
                        <TableColumn fx:id="colScheduleRemain" text="剩余" prefWidth="70"/>
                    </columns>
                </TableView>
                <VBox spacing="10" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="排班信息编辑" styleClass="form-title"/>
                    <GridPane vgap="10" hgap="10">
                        <Label text="医生*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbScheduleDoctor" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="出诊日期*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dpScheduleWorkDate" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="时段*" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbScheduleSlot" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="总号源*" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Spinner fx:id="spinScheduleTotal" GridPane.rowIndex="3" GridPane.columnIndex="1" editable="true"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="lblScheduleMessage" text=""/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="保存" onAction="#handleScheduleSave" styleClass="btn-primary"/>
                        <Button text="清除" onAction="#handleScheduleClear"/>
                        <Button text="删除" onAction="#handleScheduleDelete" styleClass="btn-danger"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </VBox>
    </Tab>

</TabPane>
