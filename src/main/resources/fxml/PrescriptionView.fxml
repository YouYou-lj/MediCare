<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.PrescriptionController"
            prefWidth="1100" prefHeight="750">

    <!-- 顶部 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="处方管理" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="查看今日处方" onAction="#handleViewToday" styleClass="btn-primary"/>
                <Button text="刷新" onAction="#handleRefresh"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间内容 -->
    <center>
        <SplitPane dividerPositions="0.3">
            <!-- 左侧：今日就诊患者列表 -->
            <VBox spacing="5">
                <padding>
                    <Insets top="5" right="10" bottom="5" left="15"/>
                </padding>
                <Label text="今日已完成就诊患者" styleClass="form-title"/>
                <TableView fx:id="tablePatients" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPatSeq" text="序号" prefWidth="50"/>
                        <TableColumn fx:id="colPatName" text="患者" prefWidth="80"/>
                        <TableColumn fx:id="colPatDoctor" text="医生" prefWidth="80"/>
                        <TableColumn fx:id="colPatDept" text="科室" prefWidth="80"/>
                    </columns>
                </TableView>
                <Label text="* 选中患者后开立处方" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
            </VBox>

            <!-- 右侧：处方编辑 -->
            <VBox spacing="10">
                <padding>
                    <Insets top="5" right="15" bottom="5" left="10"/>
                </padding>

                <!-- 患者信息 -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-bar">
                    <padding>
                        <Insets top="8" right="10" bottom="8" left="10"/>
                    </padding>
                    <Label fx:id="lblPatientInfo" text="未选择患者"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblPrescriptionStatus" text=""/>
                </HBox>

                <!-- 处方明细表格 -->
                <Label text="处方明细" styleClass="form-title"/>
                <TableView fx:id="tableItems" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colItemName" text="药品名称" prefWidth="150"/>
                        <TableColumn fx:id="colItemSpec" text="规格" prefWidth="80"/>
                        <TableColumn fx:id="colItemQty" text="数量" prefWidth="55"/>
                        <TableColumn fx:id="colItemUnit" text="单位" prefWidth="50"/>
                        <TableColumn fx:id="colItemPrice" text="单价" prefWidth="65"/>
                        <TableColumn fx:id="colItemAmount" text="金额" prefWidth="65"/>
                        <TableColumn fx:id="colItemUsage" text="用法用量" prefWidth="150"/>
                    </columns>
                </TableView>

                <!-- 添加药品 -->
                <VBox spacing="8" styleClass="form-panel">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="添加药品" styleClass="form-title"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtMedSearch" promptText="药品名称/拼音码" prefWidth="150"/>
                        <Button text="搜索" onAction="#handleSearchMedicine" styleClass="btn-primary"/>
                        <ComboBox fx:id="cmbMedicine" promptText="选择药品" prefWidth="180"/>
                        <Spinner fx:id="spinQty" prefWidth="70" editable="true"/>
                        <TextField fx:id="txtUsage" promptText="用法用量" prefWidth="150"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="添加到处方" onAction="#handleAddItem" styleClass="btn-success"/>
                        <Button text="移除" onAction="#handleRemoveItem" styleClass="btn-danger"/>
                    </HBox>
                </VBox>

                <!-- 底部操作 -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblTotalAmount" text="总金额: ￥0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblPrescMessage" text=""/>
                    <Button text="清空处方" onAction="#handleClear"/>
                    <Button text="保存处方" onAction="#handleSavePrescription" styleClass="btn-success"/>
                </HBox>

                <Separator/>

                <!-- 今日处方列表 -->
                <Label text="今日已开处方" styleClass="form-title"/>
                <TableView fx:id="tablePrescriptions" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="colPrescId" text="ID" prefWidth="45"/>
                        <TableColumn fx:id="colPrescPatient" text="患者" prefWidth="80"/>
                        <TableColumn fx:id="colPrescDoctor" text="医生" prefWidth="80"/>
                        <TableColumn fx:id="colPrescAmount" text="金额" prefWidth="70"/>
                        <TableColumn fx:id="colPrescStatus" text="状态" prefWidth="70"/>
                        <TableColumn fx:id="colPrescTime" text="开立时间" prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>

</BorderPane>
