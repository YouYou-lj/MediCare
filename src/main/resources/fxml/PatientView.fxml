<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.PatientController"
            prefWidth="1000" prefHeight="700">

    <!-- 顶部工具栏 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="患者管理" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="新建档案" onAction="#handleNew" styleClass="btn-success"/>
                <TextField fx:id="txtSearch" promptText="姓名/手机号/身份证号" prefWidth="200"/>
                <Button text="查询" onAction="#handleSearch" styleClass="btn-primary"/>
                <Button text="刷新" onAction="#handleRefresh"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间内容：全宽表格 -->
    <center>
        <VBox spacing="5">
            <padding>
                <Insets top="5" right="15" bottom="5" left="15"/>
            </padding>
            <TableView fx:id="tablePatients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colIdCard" text="身份证号" prefWidth="160"/>
                    <TableColumn fx:id="colName" text="姓名" prefWidth="80"/>
                    <TableColumn fx:id="colGender" text="性别" prefWidth="60"/>
                    <TableColumn fx:id="colBirthDate" text="出生日期" prefWidth="100"/>
                    <TableColumn fx:id="colPhone" text="手机号" prefWidth="120"/>
                    <TableColumn fx:id="colAddress" text="住址" prefWidth="220"/>
                    <TableColumn fx:id="colCreateTime" text="建档时间" prefWidth="140"/>
                    <TableColumn fx:id="colAction" text="操作" prefWidth="140"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label fx:id="lblRecordCount" text="共 0 条记录"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
