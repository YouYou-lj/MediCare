<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.MedicineDialogController"
            prefWidth="480" prefHeight="420">

    <content>
        <GridPane vgap="10" hgap="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="药品名称*" GridPane.rowIndex="0" GridPane.columnIndex="0" minWidth="65"/>
            <TextField fx:id="txtName" promptText="请输入药品名称" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="规格" GridPane.rowIndex="0" GridPane.columnIndex="2" minWidth="40"/>
            <TextField fx:id="txtSpec" promptText="如 0.25g*24粒" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="单位" GridPane.rowIndex="1" GridPane.columnIndex="0" minWidth="40"/>
            <TextField fx:id="txtUnit" promptText="如 盒、瓶、支" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="零售价" GridPane.rowIndex="1" GridPane.columnIndex="2" minWidth="50"/>
            <TextField fx:id="txtPrice" promptText="如 12.50" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="安全库存" GridPane.rowIndex="2" GridPane.columnIndex="0" minWidth="65"/>
            <Spinner fx:id="spinSafetyStock" GridPane.rowIndex="2" GridPane.columnIndex="1" editable="true"/>

            <Label text="有效期" GridPane.rowIndex="2" GridPane.columnIndex="2" minWidth="50"/>
            <DatePicker fx:id="dpExpiry" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            <Label text="批号" GridPane.rowIndex="3" GridPane.columnIndex="0" minWidth="40"/>
            <TextField fx:id="txtBatchNo" promptText="请输入批号" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="拼音码" GridPane.rowIndex="3" GridPane.columnIndex="2" minWidth="50"/>
            <TextField fx:id="txtPinyin" promptText="如 AMXL" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

            <Label text="生产厂家" GridPane.rowIndex="4" GridPane.columnIndex="0" minWidth="65"/>
            <TextField fx:id="txtManufacturer" promptText="请输入生产厂家" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

            <Label text="状态" GridPane.rowIndex="5" GridPane.columnIndex="0" minWidth="40"/>
            <ComboBox fx:id="cmbStatus" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label fx:id="lblMessage" text="" GridPane.rowIndex="6" GridPane.columnIndex="0" GridPane.columnSpan="4"/>
        </GridPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
