<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.RegistrationController"
            prefWidth="1000" prefHeight="700">

    <!-- 顶部：患者搜索 + 排班日期 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <Label text="挂号预约" styleClass="section-title"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="就诊日期:" />
                <DatePicker fx:id="dpWorkDate" promptText="选择日期"/>
                <ComboBox fx:id="cmbDepartmentFilter" promptText="全部科室" prefWidth="150"/>
                <Button text="查询号源" onAction="#handleSearchSchedule" styleClass="btn-primary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtPatientSearch" promptText="身份证号/姓名" prefWidth="180"/>
                <Button text="查找患者" onAction="#handleSearchPatient" styleClass="btn-primary"/>
                <Label fx:id="lblSelectedPatient" text="未选择患者" styleClass="user-info"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间：号源列表 + 挂号记录 -->
    <center>
        <SplitPane dividerPositions="0.5">
            <!-- 左侧：可用号源 -->
            <VBox spacing="5">
                <padding>
                    <Insets top="5" right="10" bottom="5" left="15"/>
                </padding>
                <Label text="可用号源" styleClass="form-title"/>
                <TableView fx:id="tableSchedules" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSchId" text="ID" prefWidth="40"/>
                        <TableColumn fx:id="colSchDoctor" text="医生" prefWidth="100"/>
                        <TableColumn fx:id="colSchDept" text="科室" prefWidth="100"/>
                        <TableColumn fx:id="colSchSlot" text="时段" prefWidth="70"/>
                        <TableColumn fx:id="colSchTotal" text="总号源" prefWidth="60"/>
                        <TableColumn fx:id="colSchRemain" text="剩余" prefWidth="60"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblScheduleCount" text="共 0 条"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="挂号" onAction="#handleRegister" styleClass="btn-success"/>
                </HBox>
            </VBox>

            <!-- 右侧：今日挂号记录 -->
            <VBox spacing="5">
                <padding>
                    <Insets top="5" right="15" bottom="5" left="10"/>
                </padding>
                <Label text="今日挂号记录" styleClass="form-title"/>
                <HBox spacing="5">
                    <Button text="全部" onAction="#filterAll" styleClass="btn-filter"/>
                    <Button text="候诊" onAction="#filterWaiting" styleClass="btn-filter"/>
                    <Button text="就诊中" onAction="#filterInProgress" styleClass="btn-filter"/>
                    <Button text="已完成" onAction="#filterCompleted" styleClass="btn-filter"/>
                </HBox>
                <TableView fx:id="tableRegistrations" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRegSeq" text="序号" prefWidth="50"/>
                        <TableColumn fx:id="colRegPatient" text="患者" prefWidth="80"/>
                        <TableColumn fx:id="colRegDoctor" text="医生" prefWidth="80"/>
                        <TableColumn fx:id="colRegDept" text="科室" prefWidth="80"/>
                        <TableColumn fx:id="colRegSlot" text="时段" prefWidth="60"/>
                        <TableColumn fx:id="colRegStatus" text="状态" prefWidth="70"/>
                        <TableColumn fx:id="colRegTime" text="挂号时间" prefWidth="130"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblRegCount" text="共 0 条"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="叫号" onAction="#handleCall" styleClass="btn-primary"/>
                    <Button text="完成" onAction="#handleComplete" styleClass="btn-success"/>
                    <Button text="取消" onAction="#handleCancelReg" styleClass="btn-danger"/>
                </HBox>
            </VBox>
        </SplitPane>
    </center>

    <!-- 底部状态栏 -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="footer">
            <padding>
                <Insets top="8" right="15" bottom="8" left="15"/>
            </padding>
            <Label fx:id="lblStatus" text="就绪"/>
        </HBox>
    </bottom>

</BorderPane>
