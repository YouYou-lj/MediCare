<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.AdminDialogController"
            prefWidth="360" prefHeight="320">

    <content>
        <GridPane vgap="12" hgap="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="用户名*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtUsername" promptText="请输入用户名" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="密码*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txtPassword" promptText="请输入密码" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="姓名" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtRealName" promptText="请输入真实姓名" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="状态" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbStatus" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label fx:id="lblMessage" text="" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
        </GridPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
