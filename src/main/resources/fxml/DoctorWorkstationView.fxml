<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controller.DoctorWorkstationController"
            prefWidth="1100" prefHeight="750">

    <!-- 顶部：医生选择 + 操作 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="医生工作站" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="当前医生:" />
                <ComboBox fx:id="cmbDoctor" promptText="选择医生" prefWidth="180"/>
                <Button text="刷新候诊列表" onAction="#handleRefresh" styleClass="btn-primary"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- 中间内容 -->
    <center>
        <SplitPane dividerPositions="0.35">
            <!-- 左侧：候诊列表 -->
            <VBox spacing="5">
                <padding>
                    <Insets top="5" right="10" bottom="5" left="15"/>
                </padding>
                <Label text="今日候诊列表" styleClass="form-title"/>
                <TableView fx:id="tableQueue" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colQueueSeq" text="序号" prefWidth="50"/>
                        <TableColumn fx:id="colQueuePatient" text="患者" prefWidth="80"/>
                        <TableColumn fx:id="colQueueDept" text="科室" prefWidth="80"/>
                        <TableColumn fx:id="colQueueSlot" text="时段" prefWidth="60"/>
                        <TableColumn fx:id="colQueueStatus" text="状态" prefWidth="65"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="叫号" onAction="#handleCall" styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <!-- 右侧：病历编辑 -->
            <VBox spacing="10">
                <padding>
                    <Insets top="5" right="15" bottom="5" left="10"/>
                </padding>

                <!-- 患者信息栏 -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-bar">
                    <padding>
                        <Insets top="8" right="10" bottom="8" left="10"/>
                    </padding>
                    <Label fx:id="lblPatientInfo" text="未选择患者"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblRegInfo" text=""/>
                </HBox>

                <!-- 病历表单 -->
                <Label text="病历书写" styleClass="form-title"/>
                <GridPane vgap="8" hgap="10" VBox.vgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints minWidth="70" prefWidth="70"/>
                        <ColumnConstraints prefWidth="250"/>
                        <ColumnConstraints minWidth="70" prefWidth="70"/>
                        <ColumnConstraints prefWidth="250"/>
                    </columnConstraints>

                    <Label text="主诉*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtChiefComplaint" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                    <Label text="现病史" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <TextArea fx:id="txtPresentIllness" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3"
                              prefRowCount="3" wrapText="true"/>

                    <Label text="既往史" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <TextArea fx:id="txtPastHistory" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"
                              prefRowCount="2" wrapText="true"/>

                    <Label text="体格检查" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <TextArea fx:id="txtPhysicalExam" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3"
                              prefRowCount="2" wrapText="true"/>

                    <Label text="诊断*" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDiagnosis" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                    <Label text="医嘱" GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <TextArea fx:id="txtAdvice" GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.columnSpan="3"
                              prefRowCount="2" wrapText="true"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblRecordMessage" text=""/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="保存病历" onAction="#handleSaveRecord" styleClass="btn-success"/>
                    <Button text="完成就诊" onAction="#handleComplete" styleClass="btn-primary"/>
                </HBox>

                <Separator/>

                <!-- 历史病历 -->
                <Label text="该患者历史病历" styleClass="form-title"/>
                <TableView fx:id="tableHistory" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="colHistDate" text="就诊时间" prefWidth="140"/>
                        <TableColumn fx:id="colHistDoctor" text="医生" prefWidth="80"/>
                        <TableColumn fx:id="colHistDiagnosis" text="诊断" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>

</BorderPane>
