<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.medicare.controller.LoginController"
           styleClass="login-root"
           prefWidth="1000" prefHeight="700">

    <VBox alignment="CENTER" spacing="20">
        <padding>
            <Insets top="50" right="50" bottom="50" left="50"/>
        </padding>

        <!-- 标题 -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="MediCare" styleClass="login-title"/>
            <Label text="智慧医疗门诊管理系统" styleClass="login-subtitle"/>
            <Label text="v1.0.0" styleClass="login-version"/>
        </VBox>

        <!-- 登录卡片 -->
        <VBox styleClass="login-card" spacing="15" maxWidth="380">
            <padding>
                <Insets top="35" right="40" bottom="35" left="40"/>
            </padding>

            <Label text="管理员登录" styleClass="login-card-title"/>

            <VBox spacing="5">
                <Label text="用户名" styleClass="login-label"/>
                <TextField fx:id="txtUsername" promptText="请输入用户名" styleClass="login-input"/>
            </VBox>

            <VBox spacing="5">
                <Label text="密码" styleClass="login-label"/>
                <PasswordField fx:id="txtPassword" promptText="请输入密码" styleClass="login-input"
                               onAction="#handleLogin"/>
            </VBox>

            <Label fx:id="lblMessage" text="" styleClass="login-message"/>

            <Button text="登 录" onAction="#handleLogin" styleClass="login-btn" maxWidth="Infinity"/>

            <Label text="默认账号: admin / admin123" styleClass="login-hint"/>
        </VBox>

        <!-- 底部版权 -->
        <Label text="© 2026 南京万和信息技术有限公司" styleClass="login-footer"/>
    </VBox>

</StackPane>
