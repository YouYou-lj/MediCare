<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800" prefWidth="1200" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.medicare.controller.MainController">

    <!-- 顶部标题栏 -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header">
            <padding>
                <Insets bottom="12" left="20" right="20" top="12" />
            </padding>
            <Label styleClass="app-title" text="MediCare 智慧医疗门诊管理系统">
            <font>
               <Font name="Microsoft YaHei" size="13.0" />
            </font></Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblCurrentUser" styleClass="user-info" text="未登录" />
            <Button onAction="#handleLogout" styleClass="btn-logout" text="退出" />
        </HBox>
    </top>

    <!-- 左侧导航 -->
    <left>
        <VBox prefWidth="200" spacing="5" styleClass="sidebar">
            <padding>
                <Insets bottom="15" left="10" right="10" top="15" />
            </padding>
            <Label styleClass="nav-title" text="功能导航" />
            <Separator />
            <Button maxWidth="Infinity" onAction="#showPatientMgmt" styleClass="nav-btn" text="患者管理" />
            <Button maxWidth="Infinity" onAction="#showBasicData" styleClass="nav-btn" text="基础数据" />
            <Button maxWidth="Infinity" onAction="#showRegistration" styleClass="nav-btn" text="挂号预约" />
            <Button maxWidth="Infinity" onAction="#showDoctorWorkstation" styleClass="nav-btn" text="医生工作站" />
            <Button maxWidth="Infinity" onAction="#showMedicalRecord" styleClass="nav-btn" text="病历管理" />
            <Button maxWidth="Infinity" onAction="#showPharmacy" styleClass="nav-btn" text="药品库存" />
            <Button maxWidth="Infinity" onAction="#showPrescription" styleClass="nav-btn" text="处方管理" />
            <Separator />
            <Button maxWidth="Infinity" onAction="#showSettings" styleClass="nav-btn" text="系统设置" />
        </VBox>
    </left>

    <!-- 中间内容区 -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-area">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <VBox alignment="CENTER" spacing="20">
                <Label styleClass="welcome-title" text="欢迎使用 MediCare 智慧医疗门诊管理系统" />
                <Label styleClass="welcome-subtitle" text="请从左侧导航选择功能模块" />
                <HBox alignment="CENTER" spacing="30">
                    <VBox alignment="CENTER" spacing="5" styleClass="stat-card">
                        <Label styleClass="stat-label" text="今日挂号" />
                        <Label fx:id="lblTodayReg" styleClass="stat-value" text="0" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" styleClass="stat-card">
                        <Label styleClass="stat-label" text="候诊人数" />
                        <Label fx:id="lblWaiting" styleClass="stat-value" text="0" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" styleClass="stat-card">
                        <Label styleClass="stat-label" text="库存预警" />
                        <Label fx:id="lblStockAlert" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </center>

    <!-- 底部状态栏 -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="footer">
            <padding>
                <Insets bottom="8" left="20" right="20" top="8" />
            </padding>
            <Label styleClass="footer-text" text="MediCare v1.0.0" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblStatus" styleClass="footer-text" text="就绪" />
        </HBox>
    </bottom>

</BorderPane>
